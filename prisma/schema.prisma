generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  plan_tier  String   @default("starter") @db.VarChar(16)
  created_at DateTime @default(now())
}

model daily_usage_events {
  id           Int       @id @default(autoincrement())
  user_id      Int
  date_key     String    @db.VarChar(10) // "YYYY-MM-DD"
  request_id   String    @db.VarChar(64)
  status       String    @db.VarChar(16) // "reserved" | "committed"
  reserved_at  DateTime  @default(now())
  committed_at DateTime?
  created_at   DateTime  @default(now())
}

// Part 3: cache table for pre-calculated daily aggregates
model daily_usage_cache {
  id               Int      @id @default(autoincrement())
  user_id          Int
  date_key         String   @db.VarChar(10) // "YYYY-MM-DD"
  committed_count  Int      @default(0)
  reserved_count   Int      @default(0) // excludes stale (>15min) reservations
  calculated_at    DateTime @default(now())
  // A cache entry is considered stale if calculated_at is older than a threshold
  // (e.g. 5 minutes for current day, 1 hour for past days)

  @@unique([user_id, date_key])
  @@index([user_id, date_key])
}
